{
  "name": "gamerjournal-replay-uploader",
  "version": "0.1.1",
  "description": "Watches Dota 2 replays folder, parses .dem locally with bundled Go binary (manta), uploads parsed JSON to GamerJournal.",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --publish never",
    "build:win": "electron-builder --win --publish never",
    "build:mac": "electron-builder --mac --publish never",
    "build:linux": "electron-builder --linux --publish never",
    "cli": "node scripts/cli-test.js"
  },
  "author": "Resolut1onEDL",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "chokidar": "^3.5.3",
    "electron-store": "^8.1.0",
    "express": "^4.18.2"
  },
  "build": {
    "appId": "com.gamerjournal.replay-uploader",
    "productName": "GamerJournal Replay Uploader",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico",
      "extraResources": [
        { "from": "bin/parser-win-${arch}.exe", "to": "parser.exe" }
      ]
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns",
      "extraResources": [
        { "from": "bin/parser-mac-${arch}", "to": "parser" }
      ]
    },
    "linux": {
      "target": "AppImage",
      "extraResources": [
        { "from": "bin/parser-linux-${arch}", "to": "parser" }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false
    }
  }
}
